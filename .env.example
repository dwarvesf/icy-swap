# Every NEXT_PUBLIC_ var is inlined into the browser bundle. Nothing here is
# secret, and nothing secret may be added here.

# Backend API root, no trailing slash.
NEXT_PUBLIC_BE_API=https://api.icy.so/api/v1

# Sent as `Authorization: ApiKey ...` to /swap/generate-signature. Public by
# construction, so the backend must not treat it as proof of a trusted caller.
NEXT_PUBLIC_API_KEY=

# Both must be real mainnet contract addresses. The app refuses to start
# otherwise: the swapper is the address users grant a token allowance to.
NEXT_PUBLIC_ICY_CONTRACT_ADDRESS=0xF289E3b222dd42B185b7E335fA3C5bd6D132441D
NEXT_PUBLIC_ICY_SWAPPER_CONTRACT_ADDRESS=

NEXT_PUBLIC_BTC_EXPLORER=https://mempool.space
